# ─── Painel IPTV 2 (searchdefense.top / gesapioffice.com) ────────────────────
GESAPI_USER=seu_usuario
GESAPI_PASS=sua_senha
GESAPI_RENEW_URL=https://searchdefense.top  # domínio do link de renovação do cliente

# ─── Painel IPTV 1 (painelr.top) ──────────────────────────────────────────────
PANEL_URL=https://seu-painel.painelr.top
PANEL_USER=seu_usuario
PANEL_PASS=sua_senha
RENEW_URL=https://seu-painel.appm.live  # domínio do link de renovação (se diferente do PANEL_URL)

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
EVOLUTION_URL=http://SEU_IP:8080
EVOLUTION_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=nome-da-instancia

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# ─── Acesso ao painel web ─────────────────────────────────────────────────────
ADMIN_USER=seu_usuario
ADMIN_PASS=sua_senha_forte

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-seu-access-token-aqui
MP_PRECO=25.00
GESTOR_URL=http://SEU_IP_VPS:3000
